# ============================================================
# WORKFLOW 02 — Branded Report Builder
# ============================================================

# ── DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/cam_ai

# ── COSTAR API
COSTAR_API_KEY=your_costar_api_key_here
COSTAR_API_SECRET=your_costar_api_secret_here
COSTAR_BASE_URL=https://api.costar.com/v1

# ── CREXI API
CREXI_API_KEY=your_crexi_api_key_here
CREXI_BASE_URL=https://api.crexi.com/v1

# ── CLAUDE AI (Anthropic)
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── GOOGLE MAPS
# Enable: Maps Static API, Maps JavaScript API, Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── GMAIL (for sending reports)
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
GMAIL_FROM_ADDRESS=cam@cameronnorwoodcre.com
GMAIL_FROM_NAME=Cameron Norwood | Commercial Real Estate

# ── STORAGE (where to save generated PDFs)
STORAGE_PROVIDER=dropbox
# If Dropbox:
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token
DROPBOX_REPORTS_FOLDER=/CAM-AI/Reports
# If Google Drive:
GDRIVE_FOLDER_ID=your_google_drive_folder_id

# ── REPORT BRANDING
BROKER_NAME=Cameron Norwood
BROKER_TITLE=Commercial Real Estate Broker
BROKER_COMPANY=Cameron Norwood CRE
BROKER_PHONE=(520) 555-0100
BROKER_EMAIL=cam@cameronnorwoodcre.com
BROKER_WEBSITE=cameronnorwoodcre.com
BROKER_LICENSE=AZ BR 12345678

# ── SERVER
PORT=3002
NODE_ENV=development
