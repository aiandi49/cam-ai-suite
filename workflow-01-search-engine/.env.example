# ============================================================
# WORKFLOW 01 — Search & Alert Engine
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# ── DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/cam_ai

# ── COSTAR API
# Get from your CoStar account rep
COSTAR_API_KEY=your_costar_api_key_here
COSTAR_API_SECRET=your_costar_api_secret_here
COSTAR_BASE_URL=https://api.costar.com/v1

# ── CREXI API
# Settings → API Access in your Crexi Pro account
CREXI_API_KEY=your_crexi_api_key_here
CREXI_BASE_URL=https://api.crexi.com/v1

# ── LOOPNET API
# Same CoStar group account — request from rep
LOOPNET_API_KEY=your_loopnet_api_key_here
LOOPNET_BASE_URL=https://api.loopnet.com/v1

# ── GMAIL / G SUITE
# Create OAuth 2.0 credentials at console.cloud.google.com
# Scopes needed: gmail.send, gmail.compose
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
GMAIL_FROM_ADDRESS=cam@cameronnorwoodcre.com
GMAIL_FROM_NAME=Cameron Norwood | Commercial Real Estate

# ── TWILIO SMS
# Get from twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15204440000

# ── SCHEDULER
# Cron expression for when to run daily searches
# Default: 4:00 AM every day
CRON_SCHEDULE=0 4 * * *
# Timezone for cron
CRON_TIMEZONE=America/Phoenix

# ── SERVER
PORT=3001
NODE_ENV=development

# ── SEARCH DEFAULTS
# Default search area (Tucson metro)
DEFAULT_CITY=Tucson
DEFAULT_STATE=AZ
DEFAULT_MARKET=Tucson, AZ

# ── FEATURE FLAGS
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_COSTAR=true
ENABLE_CREXI=true
ENABLE_LOOPNET=true
# Set to false to test without actually sending emails/SMS
DRY_RUN=false
