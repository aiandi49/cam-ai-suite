# ============================================================
# WORKFLOW 04 — Owner Finder / Skip Trace Engine
# ============================================================

# ── DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/cam_ai

# ── CLAUDE AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── ATTOM DATA API
# Sign up at api.attomdata.com
# ~$250-300/mo for property owner data
ATTOM_API_KEY=your_attom_api_key_here
ATTOM_BASE_URL=https://api.gateway.attomdata.com

# ── PIMA COUNTY GIS
# Public — no key needed, but we scrape carefully
PIMA_MAPS_URL=https://www.assessor.pima.gov
PIMA_GIS_URL=https://webcms.pima.gov/government/assessor/pima_maps

# ── AZ CORPORATION COMMISSION
# Public — no key needed, scrape with Playwright
AZ_CORP_URL=https://ecorp.azcc.gov
# Delay between requests (ms) to avoid rate limiting
AZ_CORP_REQUEST_DELAY=2000

# ── GOOGLE (address normalization)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── GMAIL (send outreach to owner)
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
GMAIL_FROM_ADDRESS=cam@cameronnorwoodcre.com
GMAIL_FROM_NAME=Cameron Norwood | Commercial Real Estate Tucson

# ── CALENDAR LINK
CALENDAR_LINK=https://calendly.com/cameron-norwood

# ── SCRAPING BEHAVIOR
# Time to wait between page requests (ms)
SCRAPE_DELAY_MS=1500
# Max retries on failed requests
MAX_RETRIES=3

# ── CONFIDENCE SCORING WEIGHTS
# These determine how the 0-100 confidence score is calculated
WEIGHT_PIMA_MATCH=30
WEIGHT_CORP_MATCH=30
WEIGHT_CONTACT_FOUND=40

# ── SERVER
PORT=3004
NODE_ENV=development
