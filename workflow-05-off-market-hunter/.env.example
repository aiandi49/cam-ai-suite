# ============================================================
# WORKFLOW 05 — Off-Market Property Hunter
# ============================================================

# ── DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/cam_ai

# ── CLAUDE AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── COSTAR (to check if property is already listed)
COSTAR_API_KEY=your_costar_api_key_here
COSTAR_API_SECRET=your_costar_api_secret_here
COSTAR_BASE_URL=https://api.costar.com/v1

# ── CREXI (to check if property is already listed)
CREXI_API_KEY=your_crexi_api_key_here
CREXI_BASE_URL=https://api.crexi.com/v1

# ── ATTOM DATA (property value estimation + ownership)
ATTOM_API_KEY=your_attom_api_key_here
ATTOM_BASE_URL=https://api.gateway.attomdata.com

# ── PIMA COUNTY DATA
PIMA_MAPS_URL=https://www.assessor.pima.gov
PIMA_GIS_URL=https://webcms.pima.gov/government/assessor/pima_maps
# Pima County parcel data bulk download (public)
PIMA_PARCEL_DATA_URL=https://www.assessor.pima.gov/Downloads/parcel_data.csv

# ── GOOGLE MAPS
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── GMAIL (for sending pitch emails)
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
GMAIL_FROM_ADDRESS=cam@cameronnorwoodcre.com
GMAIL_FROM_NAME=Cameron Norwood | Commercial Real Estate

# ── CALENDAR LINK
CALENDAR_LINK=https://calendly.com/cameron-norwood

# ── HUNT SETTINGS
# Minimum match score to include in results (0-100)
MIN_MATCH_SCORE=20
# Max properties to return per hunt
MAX_RESULTS_PER_HUNT=200
# Default search radius if no geo bounds given (miles)
DEFAULT_RADIUS_MILES=15
# Email send delay between pitch emails (ms)
PITCH_EMAIL_DELAY_MS=3000

# ── WF04 INTEGRATION
# This workflow calls WF04's API to trace property owners
WF04_API_URL=http://localhost:3004
WF04_API_KEY=internal_service_key_here

# ── SERVER
PORT=3005
NODE_ENV=development
