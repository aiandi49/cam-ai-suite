# ============================================================
# WORKFLOW 03 — Tenant Outreach Engine
# ============================================================

# ── DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/cam_ai

# ── CLAUDE AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── CREXI API
CREXI_API_KEY=your_crexi_api_key_here
CREXI_BASE_URL=https://api.crexi.com/v1

# ── COSTAR API
COSTAR_API_KEY=your_costar_api_key_here
COSTAR_API_SECRET=your_costar_api_secret_here
COSTAR_BASE_URL=https://api.costar.com/v1

# ── RE² AI (re2.ai — contact enrichment)
RE2_API_KEY=your_re2_api_key_here
RE2_BASE_URL=https://api.re2.ai/v1

# ── RE DAILY NEWS (Tucson lease reports)
# The website that Kam mentioned — posts weekly lease reports
RE_DAILY_NEWS_URL=https://realestatesdailynews.com
# How often to crawl for new lease data (cron)
CRAWLER_SCHEDULE=0 6 * * 1

# ── GMAIL
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
GMAIL_FROM_ADDRESS=cam@cameronnorwoodcre.com
GMAIL_FROM_NAME=Cameron Norwood | CRE Tucson

# ── CALENDAR LINK
# Calendly or similar — included in every outreach email
CALENDAR_LINK=https://calendly.com/cameron-norwood

# ── UPLOADS
UPLOAD_DIR=./assets/flyers
MAX_FILE_SIZE_MB=20

# ── CAMPAIGN LIMITS
MAX_LEADS_PER_CAMPAIGN=500
EMAIL_SEND_DELAY_MS=2000
# Date range for lease search (years back)
LEASE_LOOKBACK_YEARS=5

# ── SERVER
PORT=3003
NODE_ENV=development

# ── FEATURE FLAGS
DRY_RUN=false
ENABLE_COSTAR_COMPS=true
ENABLE_CREXI_COMPS=true
ENABLE_RE_DAILY_NEWS=true
ENABLE_RE2_ENRICHMENT=true
